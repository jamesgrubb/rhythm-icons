{
  "name": "icon-library-addin",
  "version": "1.0.0",
  "description": "Microsoft Office Add-in — curated icon picker with Azure AD auth",
  "main": "server.js",
  "scripts": {
    "dev": "webpack serve --mode development --hot",
    "build": "webpack --mode production",
    "postinstall": "npm run build",
    "server": "node server.js",
    "start": "node server.js",
    "lint": "eslint src/**/*.js",
    "db:migrate": "knex migrate:latest --knexfile db/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile db/knexfile.js",
    "db:seed": "knex seed:run --knexfile db/knexfile.js",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@microsoft/office-js": "^1.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "jwks-rsa": "^3.0.1",
    "knex": "^3.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@azure/msal-node": "^5.1.1",
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "mini-css-extract-plugin": "^2.7.6",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
