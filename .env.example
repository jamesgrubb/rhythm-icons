# =============================================
#  Environment Variables for Rhythm Icons
#  Copy this file to .env and fill in your values
# =============================================

# Azure AD Configuration (must match auth.js / Azure App Registration)
# Get these from your Azure App Registration
AZURE_TENANT_ID=YOUR-AZURE-TENANT-ID
AZURE_CLIENT_ID=YOUR-AZURE-CLIENT-ID

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# Railway provides this automatically, or for local development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rhythm_icons
DATABASE_URL=YOUR-DATABASE-URL

# Node Environment
NODE_ENV=development

# Server Port (optional, defaults to 3001)
PORT=3001

# Dev only: skip JWT signature verification so any Bearer token is accepted (unblocks 401 while fixing Azure config)
# SKIP_JWT_VERIFY=1
